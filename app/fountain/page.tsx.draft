 <p className="text-gray-700 mb-8">
 Browse homes with assumable mortgages available now. All listings show your potential monthly savings compared to a new loan at 6.5%.
 </p>
 {featured.length > 0 ? (
 <ListingCardWrapper listings={featured} />
 ) : (
 <div className="bg-gray-100 p-8 rounded-lg text-center">
 <p className="text-gray-700 text-lg">No listings currently available. We update our inventory regularly. Check back soon or contact us to be notified.</p>
 </div>
 )}
 </div>
 </section>

 {/* Lead Capture */}
 <section id="contact" className="bg-gradient-to-r from-blue-900 to-blue-800 py-12 px-4">
 <div className="max-w-2xl mx-auto">
 <LeadCaptureForm
 source="fountain-landing"
 title="Ready to Buy in Fountain?"
 subtitle="Get connected with The Assumable Guy team. We'll help you find the right assumable mortgage and close faster."
 compact={false}
 />
 </div>
 </section>

 {/* How It Works */}
 <section className="py-12 px-4 bg-gray-50">
 <div className="max-w-6xl mx-auto">
